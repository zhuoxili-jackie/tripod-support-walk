#include "crocoddyl/core/utils/callbacks.hpp"

#include "python/crocoddyl/core/core.hpp"

#define SCALAR_@SCALAR_NAME@
#define IS_FP_SCALAR_@FP_TYPE@

namespace crocoddyl {
namespace python {

template <typename Model>
struct CallbackVerboseVisitor
    : public bp::def_visitor<CallbackVerboseVisitor<Model>> {
  template <class PyClass>
  void visit(PyClass& cl) const {
    cl.def("__call__", &Model::operator(), bp::args("self", "solver"),
           "Run the callback function given a solver.\n\n"
           ":param solver: solver to be diagnostic")
        .add_property("level", &Model::get_level, &Model::set_level,
                      "verbose level")
        .add_property("precision", &Model::get_precision, &Model::set_precision,
                      "precision");
  }
};

#define CROCODDYL_CALLBACK_VERBOSE_PYTHON_BINDINGS(Scalar)                     \
  typedef CallbackVerboseTpl<Scalar> Model;                                    \
  typedef CallbackAbstractTpl<Scalar> ModelBase;                               \
  bp::register_ptr_to_python<std::shared_ptr<Model>>();                        \
  bp::class_<Model, bp::bases<ModelBase>>(                                     \
      "CallbackVerbose", "Callback function for printing the solver values.",  \
      bp::init<bp::optional<VerboseLevel, std::size_t>>(                       \
          bp::args("self", "level", "precision"),                              \
          "Initialize the differential verbose callback.\n\n"                  \
          ":param level: verbose level (default _4)\n"                         \
          ":param precision: precision of floating point output (default 5)")) \
      .def(CallbackVerboseVisitor<Model>())                                    \
      .def(CastVisitor<Model, true>())                                         \
      .def(CopyableVisitor<Model>());

void exposeCallbacks() {
#ifdef SCALAR_float64
  bp::enum_<VerboseLevel>("VerboseLevel")
      .value("_0", _0)
      .value("_1", _1)
      .value("_2", _2)
      .value("_3", _3)
      .value("_4", _4);
#endif

#ifdef IS_FP_SCALAR_TRUE
  CROCODDYL_CALLBACK_VERBOSE_PYTHON_BINDINGS(@SCALAR_TYPE@)
#endif
}

}  // namespace python
}  // namespace crocoddyl
